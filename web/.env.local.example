# Supabase (SOLO base de datos + Storage; la auth ahora es Auth0)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SOLO servidor — nunca exponer al cliente (todo el acceso a datos va por aquí)
SUPABASE_SERVICE_ROLE_KEY=

# Auth0 (@auth0/nextjs-auth0 v4) — Regular Web Application
AUTH0_DOMAIN=tu-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Cifra la cookie de sesión. Generar con: openssl rand -hex 32
AUTH0_SECRET=
# URL base de la app (local: http://localhost:3000; en Vercel se infiere)
APP_BASE_URL=http://localhost:3000

# Mercado Pago (SOLO servidor) — pagos detrás de flag; opcional por ahora
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
