---
import { invitation } from '../data/invitation';
import { asset } from '../lib/asset';
const { photos, messages } = invitation;
---

<section id="message" class="relative overflow-hidden px-6 py-20 sm:py-28">
  <div class="msg-intro mx-auto max-w-xl text-center">
    <p class="font-script text-4xl text-rose-deep sm:text-5xl">{messages.greeting}</p>
    <p class="mt-8 font-display text-xl leading-relaxed sm:text-2xl">{messages.love}</p>
  </div>

  <div class="msg-photos mx-auto mt-14 grid max-w-2xl gap-4 sm:grid-cols-3">
    {photos.map((src, i) => (
      <div class={i === 1 ? 'sm:mt-8' : ''}>
        <img
          src={asset(src)}
          alt={`Recuerdo ${i + 1}`}
          loading="lazy"
          class="msg-photo aspect-[3/4] w-full rounded-2xl border-4 border-white object-cover shadow-lg"
        />
      </div>
    ))}
  </div>

  <div class="msg-sign mt-12 text-center">
    <p class="font-script text-3xl text-rose-deep">{messages.signature}</p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // Intro (saludo + mensaje): fade + subida
    gsap.timeline({
      scrollTrigger: {
        trigger: '#message .msg-intro',
        start: 'top 85%',
        end: 'bottom 20%',
        toggleActions: 'play reverse play reverse',
      },
    }).from('#message .msg-intro', { opacity: 0, y: 60, duration: 0.8, ease: 'power2.out' });

    // Fotos: fade + subida, en cascada
    gsap.timeline({
      scrollTrigger: {
        trigger: '#message .msg-photos',
        start: 'top 80%',
        end: 'bottom 20%',
        toggleActions: 'play reverse play reverse',
      },
    }).from('#message .msg-photo', {
      opacity: 0,
      y: 80,
      stagger: 0.15,
      duration: 0.7,
      ease: 'power2.out',
    });

    // Firma: fade + subida corta
    gsap.timeline({
      scrollTrigger: {
        trigger: '#message .msg-sign',
        start: 'top 90%',
        end: 'bottom 30%',
        toggleActions: 'play reverse play reverse',
      },
    }).from('#message .msg-sign', { opacity: 0, y: 40, duration: 0.7, ease: 'power2.out' });
  }
</script>
