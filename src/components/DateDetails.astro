---
import { invitation } from '../data/invitation';
import Reveal from './Reveal.astro';
const { event } = invitation;
---

<section class="bg-blush/50 px-6 py-20 sm:py-28">
  <Reveal class="mx-auto max-w-lg text-center">
    <p class="text-sm uppercase tracking-[0.3em] text-rose-deep">Nuestra cita</p>
    <h2 class="mt-3 font-display text-4xl sm:text-5xl">Detalles</h2>

    <dl class="mt-10 space-y-6 text-lg">
      <div>
        <dt class="font-script text-2xl text-rose-deep">🎬 Película</dt>
        <dd class="font-display text-2xl">{event.movie}</dd>
      </div>
      <div>
        <dt class="font-script text-2xl text-rose-deep">🗓️ Cuándo</dt>
        <dd class="font-display text-2xl">{event.datetimeLabel}</dd>
      </div>
    </dl>

    {event.callLink ? (
      <a
        href={event.callLink}
        target="_blank"
        rel="noopener"
        class="mt-10 inline-block rounded-full bg-wine px-8 py-4 font-body text-lg font-semibold text-cream shadow-lg transition hover:scale-105 hover:bg-rose-deep active:scale-95"
      >
        {event.callLabel}
      </a>
    ) : (
      <p class="mt-10 font-display text-2xl text-rose-deep">{event.callLabel}</p>
    )}
  </Reveal>
</section>
